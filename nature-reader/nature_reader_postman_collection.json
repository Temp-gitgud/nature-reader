				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const jsonData = pm.response.json();",
									"if (jsonData.accessToken) {",
									"    pm.environment.set(\"token\", jsonData.accessToken);",
									"    console.log(\"Access token automatically saved to environment variable 'token'!\");",
									"}"
								],
								"type": "text/javascript"
							}
